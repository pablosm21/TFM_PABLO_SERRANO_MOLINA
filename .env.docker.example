# Copy this file to .env.docker and adjust for your machine.
JWT_SECRET=replace_with_a_long_random_secret

# Host path with TFM-SIMULATION project to mount inside backend container.
SIMULATION_HOST_PATH=/home/psmolina/TFM-SIMULATION

# Project root used by backend commands and make_build.sh.
CURRENT_PROJECT=/simulation/project

# Frontend build-time variables
REACT_APP_API_BASE_URL=http://localhost:3001
REACT_APP_SOCKET_URL=http://localhost:3001
REACT_APP_STATUS_POLL_INTERVAL_MS=3000
