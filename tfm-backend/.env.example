# BASE DE DATOS MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=tfm_unir

# JWT
JWT_SECRET=change_this_with_a_long_random_secret
JWT_EXPIRE=7d

# SERVER
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:3000
SOCKET_CORS_ORIGINS=http://localhost:3000

# EXECUTION LIMITS
COMMAND_TIMEOUT_MS=120000
COMMAND_MAX_BUFFER_BYTES=1048576

# FRONTEND POLLING
STATUS_POLL_INTERVAL_MS=3000

# SIMULATION PROJECT ROOT (host path in local, mounted path in Docker)
SIMULATION_ROOT=/home/psmolina/TFM-SIMULATION
